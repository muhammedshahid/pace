{
  "name": "@shahid-labs/pace",
  "version": "3.1.2",
  "description": "Perceptual Adaptive Contrast Enhancement (PACE): A fully adaptive image enhancement framework for improving visual quality while preserving structural fidelity.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/pace.cjs",
  "module": "./dist/pace.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pace.esm.js",
      "require": "./dist/pace.cjs",
      "default": "./dist/pace.esm.js"
    }
  },
  "bin": {
    "pace": "cli/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "cli",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node cli/index.js",
    "test": "node --test",
    "example": "node examples/basic.js",
    "lint": "eslint src cli examples tests",
    "lint:fix": "eslint src cli examples tests --fix",
    "clean": "rimraf dist",
    "build": "npm run build:esm && npm run build:cjs && npm run build:cdn",
    "build:esm": "esbuild src/index.js --bundle --format=esm --sourcemap --outfile=dist/pace.esm.js",
    "build:cjs": "esbuild src/index.js --bundle --format=cjs --platform=node --outfile=dist/pace.cjs",
    "build:cdn": "esbuild src/index.js --bundle --minify --format=iife --global-name=PACE --outfile=dist/pace.min.js",
    "build:watch": "npm run build -- --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "image-processing",
    "image-enhancement",
    "contrast-enhancement",
    "clahe",
    "low-light",
    "computer-vision",
    "image-quality",
    "oklab",
    "perceptual",
    "cli",
    "javascript"
  ],
  "author": "Mohd. Shahid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhammedshahid/pace.git"
  },
  "bugs": {
    "url": "https://github.com/muhammedshahid/pace/issues"
  },
  "homepage": "https://github.com/muhammedshahid/pace#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "rimraf": "^6.1.3"
  }
}