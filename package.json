{
  "name": "pace",
  "version": "1.0.0",
  "description": "Perceptual Adaptive Contrast Enhancement (PACE): A fully adaptive image enhancement framework for improving visual quality while preserving structural fidelity.",
  "type": "module",
  "main": "dist/pace.cjs.js",
  "module": "dist/pace.esm.js",
  "exports": {
    ".": {
      "require": "./dist/pace.cjs.js",
      "import": "./dist/pace.esm.js",
      "default": "./dist/pace.esm.js"
    }
  },
  "bin": {
    "pace": "./cli/index.js"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  },
  "scripts": {
    "start": "node cli/index.js",
    "test": "node --test",
    "example": "node examples/basic.js",
    "prepublishOnly": "npm run build",
    "build": "npm run build:esm && npm run build:cjs && npm run build:cdn",
    "build:esm": "esbuild src/index.js --bundle --format=esm --outfile=dist/pace.esm.js",
    "build:cjs": "esbuild src/index.js --bundle --format=cjs --outfile=dist/pace.cjs.js",
    "build:cdn": "esbuild src/index.js --bundle --minify --format=iife --global-name=PACE --outfile=dist/pace.min.js"
  },
  "keywords": [
    "image-processing",
    "image-enhancement",
    "contrast-enhancement",
    "clahe",
    "low-light",
    "computer-vision",
    "image-quality",
    "oklab",
    "perceptual",
    "npm",
    "cli",
    "image-processing-library",
    "javascript"
  ],
  "files": [
    "dist",
    "cli",
    "src",
    "README.md",
    "LICENSE"
  ],
  "author": "Mohd. Shahid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammedshahid/pace"
  },
  "bugs": {
    "url": "https://github.com/muhammedshahid/pace/issues"
  },
  "homepage": "https://github.com/muhammedshahid/pace#readme",
  "optionalDependencies": {
    "sharp": "^0.33.0"
  },
  "engines": {
    "node": ">=18"
  }
}
